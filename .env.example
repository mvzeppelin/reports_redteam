# ─── Banco de Dados ───────────────────────────────────────────────────────────
POSTGRES_DB=auth_db
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=troque_em_producao_db

# ─── Segredos da Aplicação ────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
OTP_SECRET=troque_em_producao_otp_secret_32chars
SESSION_SECRET=troque_em_producao_session_secret_32chars

# ─── Email ────────────────────────────────────────────────────────────────────
# Provedor: smtp (padrão, usa MailHog em dev) | resend (produção)
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@auth.local
# Nome amigavel exibido no campo "De:" do e-mail (opcional)
# EMAIL_FROM_NAME=Portal de Relatórios Red Team

# Resend (produção) — obrigatório quando EMAIL_PROVIDER=resend
# Crie sua API key em: https://resend.com/api-keys
# O EMAIL_FROM deve usar um domínio verificado no Resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@seudominio.com

# Proxy de saída para o Resend (opcional) — formato: http://host:porta
# Útil em redes sem acesso direto à internet
# HTTP_PROXY=http://192.168.15.4:8080
# Desabilita verificação TLS no proxy — necessário quando o proxy intercepta HTTPS (ex: Burp Suite)
# Usar apenas em ambiente de desenvolvimento/teste
# PROXY_INSECURE=false

# SMTP — usado quando EMAIL_PROVIDER=smtp
# Para desenvolvimento, aponte para o MailHog:
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Ignorar STARTTLS — necessário em servidores SMTP internos que não suportam TLS
# SMTP_IGNORE_TLS=false
# Aceitar certificados TLS inválidos/auto-assinados no SMTP
# SMTP_TLS_REJECT_UNAUTHORIZED=true

# Para produção via SMTP (ex: Gmail):
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu@email.com
# SMTP_PASS=sua_senha_de_app

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_DURATION_SECONDS=300      # 5 minutos de validade do OTP
OTP_COOLDOWN_SECONDS=180      # 3 minutos de cooldown por e-mail / botão reenviar

# ─── Sessão ───────────────────────────────────────────────────────────────────
SESSION_DURATION_SECONDS=86400  # 24 horas
# Habilitar flag Secure no cookie — obrigatório com HTTPS, manter false em HTTP
COOKIE_SECURE=false

# ─── Portas ───────────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
# Ativar HTTPS (requer certs/cert.pem e certs/key.pem — ver README)
HTTPS_ENABLED=false

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Requisições de OTP por IP
OTP_REQUEST_IP_MAX=10
OTP_REQUEST_IP_WINDOW_SECONDS=600   # janela de 10 minutos

# Tentativas de verificação de OTP por IP
OTP_VERIFY_IP_MAX=10
OTP_VERIFY_IP_WINDOW_SECONDS=300    # janela de 5 minutos

# Bloqueio após atingir rate limit (segundos)
RATE_LIMIT_BLOCK_SECONDS=900        # 15 minutos bloqueado
